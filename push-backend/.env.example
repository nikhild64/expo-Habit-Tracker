# ─── Push backend env ─────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in the values. The same vars are configured
# in the Vercel project's "Environment Variables" panel for production.

# Port the server listens on (local dev only — Vercel ignores this).
PORT=4000

# ─── Upstash Redis ────────────────────────────────────────────────────────────
# Required for token + subscription persistence. Create a database at
# https://console.upstash.com → REST API tab → copy URL + read/write token.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Auth keys ────────────────────────────────────────────────────────────────
# ADMIN_API_KEY  — full access (dashboard, /send, manual summary triggers).
# DEVICE_API_KEY — device endpoints (/register, /unregister, /web/*, /api/snooze).
# Leave both blank for an unauthenticated local-dev fallback (NEVER in prod).
ADMIN_API_KEY=
DEVICE_API_KEY=

# Auto-injected by Vercel Cron at deploy time as "Authorization: Bearer ...".
# Only set explicitly for local cron simulation (`curl -H "Authorization: Bearer
# <secret>" http://localhost:4000/api/web-tick`).
CRON_SECRET=

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated allow-list (e.g. https://habitly.app,https://habitly-web.vercel.app).
# Empty / unset = allow all origins.
ALLOWED_ORIGIN=

# ─── Expo push (mobile app) ───────────────────────────────────────────────────
# Optional: only required if you enabled "Enhanced Security for Push Notifications"
# on your Expo account (https://expo.dev/accounts/[account]/settings/access-tokens).
EXPO_ACCESS_TOKEN=

# ─── Daily summary cron display ───────────────────────────────────────────────
# Cosmetic-only — the actual schedule is in vercel.json. These let the admin
# dashboard show the right IST time when you change the cron.
DAILY_SUMMARY_UTC_HOUR=3
DAILY_SUMMARY_UTC_MINUTE=30

# ─── Cosma AI (Gemini + Firebase) ────────────────────────────────────────────
# Required for /cosma/ai/{chat,rashifal,report} endpoints used by the Cosma
# horoscope app. Without these, those endpoints return 401 or 503 and the app
# falls back to local templated readings.

# Get from https://aistudio.google.com → "Get API key".
GEMINI_API_KEY=

# From the Firebase service-account JSON for project habittracker-cae2c.
# (Firebase Console → Project Settings → Service accounts → Generate new
#  private key → download JSON → copy the 3 fields below.)
FIREBASE_PROJECT_ID=habittracker-cae2c
FIREBASE_CLIENT_EMAIL=
# Paste the multi-line private key including literal "\n" escape sequences,
# wrapped in double quotes. cosma-ai.js converts the "\n" back to newlines
# at startup.
FIREBASE_PRIVATE_KEY=""

# ─── Web Push (VAPID) ─────────────────────────────────────────────────────────
# Generate ONCE per environment with:
#
#     npx web-push generate-vapid-keys
#
# Then paste the values below (and set them in your Vercel project env).
# VAPID_SUBJECT must be a `mailto:` URL (or an https URL you control). It is
# sent to push services so they can contact you about deliverability issues.
#
# DO NOT commit real keys to git — these placeholders are intentionally invalid.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:nikhildhawan.dev@gmail.com
