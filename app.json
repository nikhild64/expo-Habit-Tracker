{
  "expo": {
    "name": "Habitly",
    "slug": "habit-tracker",
    "version": "1.0.21",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "habittracker",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/icon.png",
      "bundleIdentifier": "com.nikhild64.habittracker",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Use Face ID to unlock Habitly and protect your habit data."
      }
    },
    "android": {
      "permissions": [
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.RECEIVE_BOOT_COMPLETED"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#FF8B1F",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.nikhild64.habittracker",
      "googleServicesFile": "google-services.json"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0F0F14",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 240,
          "resizeMode": "contain",
          "dark": {
            "backgroundColor": "#0F0F14"
          }
        }
      ],
      [
        "expo-notifications",
        {
          "defaultChannel": "habit-reminders"
        }
      ],
      "expo-sharing",
      "expo-web-browser",
      [
        "expo-secure-store",
        {
          "faceIDPermission": "Use Face ID to unlock Habitly and protect your habit data."
        }
      ],
      [
        "expo-quick-actions",
        {
          "androidIcons": {
            "add": {
              "foregroundImage": "./assets/images/shortcuts/add.png",
              "backgroundColor": "#FF8B1F"
            },
            "today": {
              "foregroundImage": "./assets/images/shortcuts/today.png",
              "backgroundColor": "#10B981"
            },
            "insights": {
              "foregroundImage": "./assets/images/shortcuts/insights.png",
              "backgroundColor": "#8B5CF6"
            },
            "journal": {
              "foregroundImage": "./assets/images/shortcuts/journal.png",
              "backgroundColor": "#3B82F6"
            }
          }
        }
      ],
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "HabitlyTodayWidget",
              "label": "Habitly · Today",
              "minWidth": "180dp",
              "minHeight": "100dp",
              "targetCellWidth": 3,
              "targetCellHeight": 2,
              "minResizeWidth": "110dp",
              "minResizeHeight": "60dp",
              "maxResizeWidth": "360dp",
              "maxResizeHeight": "320dp",
              "resizeMode": "horizontal|vertical",
              "description": "Your habits for today",
              "previewImage": "./assets/images/icon.png",
              "updatePeriodMillis": 1800000
            }
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "1834290c-f62c-483e-b327-6a3edd19ee50"
      }
    },
    "owner": "nikhild64"
  }
}
