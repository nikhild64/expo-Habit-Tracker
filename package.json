{
  "name": "expo-habit-tracker",
  "main": "expo-router/entry",
  "version": "1.0.13",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "assets:gen": "node scripts/generate-assets.mjs",
    "clean": "expo prebuild --clean",
    "build:android:apk": "expo prebuild --platform android && node scripts/bump-version.js && node scripts/setup-signing.js && cd android && gradlew.bat assembleRelease && cd .. && node scripts/sync-eas-version.js",
    "build:android:aab": "expo prebuild --platform android && node scripts/bump-version.js && node scripts/setup-signing.js && cd android && gradlew.bat bundleRelease && cd .. && node scripts/sync-eas-version.js",
    "build:local": "eas build --platform android --local --profile production",
    "build:local:preview": "eas build --platform android --local --profile preview",
    "build:eas": "eas build --platform android --profile production",
    "build:eas:preview": "eas build --platform android --profile preview",
    "update": "eas update --channel production --message 'update'",
    "submit": "eas submit --platform android --profile production"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@react-navigation/elements": "^2.9.10",
    "@react-navigation/native": "^7.1.33",
    "babel-preset-expo": "~55.0.8",
    "expo": "~55.0.26",
    "expo-clipboard": "~55.0.13",
    "expo-constants": "~55.0.16",
    "expo-device": "~55.0.17",
    "expo-font": "~55.0.8",
    "expo-glass-effect": "~55.0.11",
    "expo-haptics": "~55.0.14",
    "expo-image": "~55.0.11",
    "expo-linking": "~55.0.15",
    "expo-notifications": "~55.0.23",
    "expo-router": "~55.0.16",
    "expo-splash-screen": "~55.0.21",
    "expo-status-bar": "~55.0.6",
    "expo-symbols": "~55.0.9",
    "expo-system-ui": "~55.0.18",
    "expo-web-browser": "~55.0.16",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-draggable-flatlist": "^4.0.3",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.7.4",
    "sp-react-native-in-app-updates": "^1.5.0"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "babel-plugin-module-resolver": "^5.0.3",
    "expo-dev-client": "~55.0.35",
    "opentype.js": "^2.0.0",
    "sharp": "^0.35.2",
    "typescript": "~5.9.2"
  },
  "private": true
}
