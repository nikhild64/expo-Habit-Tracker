{
  "name": "webapp",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build && node scripts/append-push-worker.mjs",
    "build:dev": "ng build --configuration development",
    "watch": "ng build --watch --configuration development",
